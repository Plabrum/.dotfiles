#!/usr/bin/env python3
"""agent-loop — spawn repeating Claude Code sessions against a Linear or GitHub Issues backlog."""

import argparse
import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timedelta
from pathlib import Path

# ---------------------------------------------------------------------------
# Picker constants
# ---------------------------------------------------------------------------

DEFAULT_SKIP_LABELS = ["epic", "tracker"]
DEFAULT_PRIORITY_LABELS = ["bug"]
EPIC_TITLE_RE = re.compile(r"^Epic:\s", re.IGNORECASE)
DEPENDENCY_RE = re.compile(r"\b(?:blocked by|depends on)\s+#(\d+)", re.IGNORECASE)
PR_CLOSES_RE = re.compile(r"\b(?:closes|fixes|resolves)\s+#(\d+)\b", re.IGNORECASE)
TICKET_MARKER = "{{TICKET}}"
LINEAR_GRAPHQL_URL = "https://api.linear.app/graphql"

SCRIPT_DIR = Path(__file__).resolve().parent
DEFAULT_PROMPTS_DIR = SCRIPT_DIR / "agent-prompts"
AVAILABLE_ROLES = ["engineer", "qa"]

# Per-role allowlists passed to `claude --allowedTools`. Anything not listed
# will prompt at runtime — and since these run headless via `claude -p`, a
# prompt = a hang. So the allowlist must cover everything the role legitimately
# does, and intentionally omit destructive surfaces (force-push, hard reset,
# repo/issue delete, deploy/submit/release, db reset --linked, rm -rf, .env
# edits) so they fail loudly instead of executing silently.
#
# Custom prompts (--prompt without --role) fall back to
# --dangerously-skip-permissions for backward compatibility.
ROLE_ALLOWED_TOOLS = {
    "qa": [
        # GitHub backlog — read + file bugs. No close/edit/delete.
        "Bash(gh issue list:*)",
        "Bash(gh issue view:*)",
        "Bash(gh issue create:*)",
